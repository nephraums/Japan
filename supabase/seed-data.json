  "place_facts": [
    {
      "place": "Dotonbori",
      "city": "Osaka",
      "fact": "Osaka’s neon-heavy food district, famous for takoyaki, giant signs, and the Glico running man.",
      "event_title": "Dotonbori, Shinsaibashi, Amerikamura, Orange Street"
    },
    {
      "place": "Kuromon Ichiba Market",
      "city": "Osaka",
      "fact": "A covered food market known for seafood, grilled snacks, fruit and grazing-style eating.",
      "event_title": "Kuromon Ichiba Market"
    },
    {
      "place": "Osaka Castle",
      "city": "Osaka",
      "fact": "Toyotomi Hideyoshi began the original castle in 1583. Today’s main tower is a museum reconstruction surrounded by large stone walls and moats.",
      "event_title": "Universal Studios Japan or Osaka Castle"
    },
    {
      "place": "Shinsekai",
      "city": "Osaka",
      "fact": "This retro entertainment district grew in the early 1900s. Tsutenkaku tower is its landmark, and kushikatsu is the classic local snack.",
      "event_title": "Shinsekai; dinner in Ura Namba or Hozenji Yokocho"
    },
    {
      "place": "Fushimi Inari",
      "city": "Kyoto",
      "fact": "Known for thousands of vermilion torii gates climbing the mountain behind the shrine. Fox statues appear throughout because foxes are regarded as messengers of Inari.",
      "event_title": "Train Osaka to Kyoto; Fushimi Inari"
    },
    {
      "place": "Gion",
      "city": "Kyoto",
      "fact": "Kyoto’s historic entertainment district with preserved streets and traditional atmosphere. Its geiko and maiko are working artists, so give them space and avoid blocking private lanes.",
      "event_title": "Gion, Pontocho, Kamo River dinner"
    },
    {
      "place": "Nishiki Market",
      "city": "Kyoto",
      "fact": "The narrow covered shopping street is often called Kyoto’s Kitchen. Many stalls specialise in one food or ingredient passed down through generations.",
      "event_title": "Nishiki Market; Kiyomizu-dera; Ninenzaka/Sannenzaka"
    },
    {
      "place": "Kiyomizu-dera",
      "city": "Kyoto",
      "fact": "The temple’s famous wooden stage projects from the hillside without nails. Its name means Pure Water Temple, after the Otowa waterfall below.",
      "event_title": "Nishiki Market; Kiyomizu-dera; Ninenzaka/Sannenzaka"
    },
    {
      "place": "Ninenzaka and Sannenzaka",
      "city": "Kyoto",
      "fact": "These preserved sloping streets lead toward Kiyomizu-dera and are lined with traditional buildings, small shops and teahouses.",
      "event_title": "Nishiki Market; Kiyomizu-dera; Ninenzaka/Sannenzaka"
    },
    {
      "place": "Pontocho and the Kamo River",
      "city": "Kyoto",
      "fact": "Pontocho is a narrow dining alley beside the Kamo River. In summer, some restaurants build raised riverside terraces called kawayuka.",
      "event_title": "Gion, Pontocho, Kamo River dinner"
    },
    {
      "place": "Arashiyama",
      "city": "Kyoto",
      "fact": "The district is known for its bamboo grove, temple gardens and Togetsukyo Bridge. Early morning is usually the calmest time to explore.",
      "event_title": "Optional Arashiyama or slow Kyoto morning"
    },
    {
      "place": "Shibuya Crossing",
      "city": "Tokyo",
      "fact": "One of Tokyo’s best-known intersections and a strong first-night Tokyo moment. The scramble phase lets pedestrians cross in every direction at once.",
      "event_title": "Shibuya Crossing, Hachiko, Shibuya Sky, dinner"
    },
    {
      "place": "Harajuku",
      "city": "Tokyo",
      "fact": "Youth culture, fashion, Takeshita Street snacks, and easy access to Meiji Shrine.",
      "event_title": "Meiji Shrine; Harajuku; Takeshita Street"
    },
    {
      "place": "Hachiko",
      "city": "Tokyo",
      "fact": "The statue remembers an Akita dog famous for continuing to wait at Shibuya Station for his owner. It is now one of Tokyo’s best-known meeting points.",
      "event_title": "Shibuya Crossing, Hachiko, Shibuya Sky, dinner"
    },
    {
      "place": "Shibuya Sky",
      "city": "Tokyo",
      "fact": "This open-air observation deck sits above Shibuya Scramble Square and looks directly over the crossing and Tokyo skyline.",
      "event_title": "Shibuya Crossing, Hachiko, Shibuya Sky, dinner"
    },
    {
      "place": "Meiji Shrine",
      "city": "Tokyo",
      "fact": "Meiji Jingu is dedicated to Emperor Meiji and Empress Shoken. Its forest was planted with donated trees from across Japan.",
      "event_title": "Meiji Shrine; Harajuku; Takeshita Street"
    },
    {
      "place": "Takeshita Street",
      "city": "Tokyo",
      "fact": "The compact pedestrian street is associated with youth fashion, colourful sweets and small independent shops; it is busiest after late morning.",
      "event_title": "Meiji Shrine; Harajuku; Takeshita Street"
    },
    {
      "place": "Akihabara",
      "city": "Tokyo",
      "fact": "Tokyo’s electronics, anime, gaming and arcade district. Look above street level too: many specialist shops and cafés occupy upper floors.",
      "event_title": "Akihabara gaming/anime/electronics"
    },
    {
      "place": "Asakusa",
      "city": "Tokyo",
      "fact": "Home to Senso-ji, Tokyo’s oldest temple, and Nakamise shopping street.",
      "event_title": "Asakusa, Senso-ji, Nakamise"
    },
    {
      "place": "Senso-ji and Nakamise",
      "city": "Tokyo",
      "fact": "Senso-ji is traditionally dated to 628. Nakamise, the shopping approach between Kaminarimon gate and the temple, sells snacks and souvenirs.",
      "event_title": "Asakusa, Senso-ji, Nakamise"
    },
    {
      "place": "Tokyo DisneySea",
      "city": "Tokyo",
      "fact": "Opened in 2001, DisneySea is a sea-themed park unique to Tokyo Disney Resort, organised around themed ports rather than traditional lands.",
      "event_title": "Tokyo DisneySea and/or Disneyland"
    },
    {
      "place": "teamLab",
      "city": "Tokyo",
      "fact": "teamLab creates immersive digital artworks that respond to movement and change over time. The experience can involve dark rooms, mirrors and water.",
      "event_title": "teamLab; final dinner in Ebisu or Nakameguro"
    }
  ]
